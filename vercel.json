{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "outputDirectory": "public",
  "buildCommand": "composer install --no-dev --optimize-autoloader",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "cleanUrls": true,
  "env": {
    "VERCEL_ANALYZE_BUILD_OUTPUT": "1"
  }
}
